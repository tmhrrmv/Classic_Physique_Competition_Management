# ============================================================
# .env.example — Plantilla de variables de entorno
# Copia este archivo a .env y rellena los valores reales
# NUNCA subas .env a GitHub
# ============================================================

# Base de datos (Railway)
DB_HOST=roundhouse.proxy.rlwy.net
DB_PORT=52392
DB_NAME=railway
DB_USER=root
DB_PASS=

# JWT — genera un secreto seguro aleatorio
# Ejemplo: openssl rand -hex 32
JWT_SECRET=

# Entorno: development o production
APP_ENV=development

# URL pública de la app (sin trailing slash)
APP_URL=http://localhost

# CORS — origen permitido en producción
# Ejemplo: https://tudominio.up.railway.app
ALLOWED_ORIGIN=*

# Proxies de confianza (separados por coma)
TRUSTED_PROXIES=127.0.0.1,::1
